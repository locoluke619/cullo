# ============================================
#  CULLO — Configuration
# ============================================
# Copy this file to .env and fill in your values.
# This file is safe to share — your actual .env is private.

# --- Your Anthropic API Key ---
# Get one at: https://console.anthropic.com
# 1. Create an account and add $5 in credits
# 2. Go to "API Keys" in the left sidebar
# 3. Click "Create Key" and paste it below
ANTHROPIC_API_KEY=your-api-key-here

# --- Photo Folder ---
# Where are your photos?
#
# Default: put them in the "photos" folder inside this project.
# Just drop your JPGs there and leave this line as-is:
PHOTOS_FOLDER=photos
#
# Or point to any folder on your computer:
# PHOTOS_FOLDER=/Users/yourname/Pictures/MyShoot
# PHOTOS_FOLDER=/Volumes/SD Card/DCIM/100CANON

# --- Analysis Settings ---
# Top % of photos to send to Claude (20 = top 20%)
TOP_PERCENT=20
# Hard cap on Claude-analyzed photos (controls cost)
MAX_CLAUDE_PHOTOS=50

# --- Website Settings ---
SITE_TITLE=My Photography
SITE_AUTHOR=Your Name

# --- Client Proof ---
# Your email address — pre-filled in the "Send My Picks" button for clients
PHOTOGRAPHER_EMAIL=you@example.com
