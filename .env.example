# ============================================
# SETTINGS FOR YOUR PHOTOGRAPHY PORTFOLIO
# ============================================
# Copy this file to .env and fill in your values
# (In Terminal, type: cp .env.example .env)

# Your Anthropic API Key
# Get one free at: https://console.anthropic.com
# 1. Create an account
# 2. Go to "API Keys" in the left sidebar
# 3. Click "Create Key"
# 4. Copy the key and paste it below
ANTHROPIC_API_KEY=your-api-key-here

# Path to your photo folder (the full path on your computer)
# On Mac: right-click the folder > "Get Info" > copy the path
# Example: /Users/yourname/Desktop/sephotography/micheals pictures
PHOTOS_FOLDER=/Users/lukeengel/Desktop/sephotography/micheals_pictures

# What percentage of your best photos to send to Claude for analysis
# 20 means the top 20% — higher = more photos analyzed but costs more
TOP_PERCENT=20

# Maximum number of photos to analyze with Claude (controls cost)
# At ~$0.01-0.02 per photo, 50 photos costs about $0.50-$1.00
MAX_CLAUDE_PHOTOS=50

# Your website title and name
SITE_TITLE=Michael's Photography
SITE_AUTHOR=Michael
